# Twilio Configuration
# Get these from your Twilio Console (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# App Configuration
# Optional: Set the timezone for reminders (e.g., America/New_York)
# APP_TIMEZONE=America/New_York

# SEC-17: JWT signing key. Without this, sessions invalidate on every restart.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET_KEY=CHANGE_ME_generate_a_random_key


HASS_URL=http://YOUR_HA_IP:8123
HASS_TOKEN=YOUR_LONG_LIVED_ACCESS_TOKEN